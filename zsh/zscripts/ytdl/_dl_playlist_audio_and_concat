# ffmpeg -i input.opus -ss 00:00:00 -t 00:16:45 -acodec copy output.opus
#
# To cut with frame accuracy use dot notation
# ffmpeg -i input.opus -ss 00:00:00.00 -t 00:16:45.00 -acodec copy output.opus

