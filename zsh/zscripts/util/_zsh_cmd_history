#!/usr/bin/env zsh

################################################################################
# `fzf` zsh history and append selection to the command line.
# -----------------------------------------------------------
# Args:
#     None
# Exoprts:
#     BUFFER
#     CURSOR
################################################################################

emulate -L zsh

local selection; selection=$(
    typeset -a lines=( "${(@f)$(history 0)}" )

    local line
    for line in "${lines[@]}"; do
        typeset -a split_line=( "${(s: :)line}" )
        builtin printf '%b\n' \
            "\e[32m${split_line[3]}\e[0m ${split_line[4,-1]}"
    done | fzf \
        --tac \
        --no-preview \
        --no-multi \
        --header-border=top \
        --header=' Zsh command history.'
)

if [[ -n "$selection" ]]; then
    BUFFER="$selection"
    CURSOR=${#BUFFER}
    zle redisplay
fi
