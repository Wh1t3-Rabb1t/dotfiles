#!/usr/bin/env zsh

################################################################################
# `cd` into a child dir of the cwd.
# ---------------------------------
# Args:     None
# Exports:  BUFFER
################################################################################

emulate -L zsh

local hidden_key='?'
local cwd_key='>'

local RELOAD_OPTS='
    local fd_cmd="fd --type=directory --color=always"
    local content=" Cd into directory."
    local label=""

    [[ -z '\$FZF_HEADER_LABEL' ]] && label=" H:n D:n " || label='\$FZF_HEADER_LABEL'

    case '\$FZF_KEY' in
        "'"$hidden_key"'")
            [[ '$\label' == *"H:y"* ]] && label="${label/H:y/H:n}" || label="${label/H:n/H:y}"
            ;;
        "'"$cwd_key"'")
            [[ '$\label' == *"D:y"* ]] && label="${label/D:y/D:n}" || label="${label/D:n/D:y}"
            ;;
    esac

    if [[ '\$label' == *"H:n"* ]]; then
        content+="\n'${hidden_key}' : Show dotfiles."
    else
        fd_cmd+=" --hidden"
        content+="\n'${hidden_key}' : Hide dotfiles."
    fi

    if [[ '\$label' == *"D:n"* ]]; then
        fd_cmd+=" --max-depth=1"
        content+="\n'${cwd_key}' : Expand dir tree."
    else
        content+="\n'${cwd_key}' : Collapse dir tree."
    fi

    printf "%b" \
        "change-header('\${content}')" \
        "+change-header-label('\${label}')" \
        "+reload('\${fd_cmd}')"
'

local selection; selection=$(
    fd \
        --type=directory \
        --color=always \
        --max-depth=1 \
    | fzf \
        --tac \
        --header-border=top \
        --bind="${hidden_key}:transform:${RELOAD_OPTS}" \
        --bind="${cwd_key}:transform:${RELOAD_OPTS}" \
        --bind="start:transform:${RELOAD_OPTS}"
)

if [[ -n "$selection" ]]; then
    BUFFER="cd ${selection:q}"
    zle accept-line
fi
