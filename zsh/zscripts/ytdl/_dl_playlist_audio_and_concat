#!/usr/bin/env zsh

################################################################################
# Download a series of audio files from a youtube playlist in opus format, then
# concatenate into a single audio file.
# -------------------------------------
# Arguments:
#     1) Newly created file name
#     2) URL
# Globals:
#     None
################################################################################

emulate -L zsh

set -e
setopt pipefail null_glob

local function _dl_and_concat_yt_playlist() {
    if (( $# != 2 )); then
        REPLY="ERROR: Two args expected. \n1. File name \n2. url"
        return 1
    fi

    local title="$1"
    local url="$2"
    local tmp_dir="./yt_tmp_$$"
    {
        mkdir -p "$tmp_dir" || {
            REPLY="mkdir failed"
            return 1
        }

        yt-dlp \
            -x \
            --audio-format opus \
            -o "${tmp_dir}/%(playlist_index)05d.%(ext)s" \
            "$url" || {
                REPLY="yt-dlp failed"
                return 1
            }

        typeset -a files=( ${tmp_dir}/*.opus )

        # Ensure files exist
        (( ${#files} )) || {
            REPLY="No files downloaded"
            return 1
        }

        # Build concat list
        local list_file="${tmp_dir}/files.txt"
        : > "$list_file"

        for file in "${files[@]}"; do
            printf "file '%s'\n" "${file:t}" >> "$list_file"
        done

        ffmpeg -f concat -safe 0 -i "$list_file" -c copy "${title}.opus" || {
            REPLY="ffmpeg failed"
            return 1
        }

    # Ensure cleanup of tmp_dir if dl fails (can't trap function exit)
    } always {
        rm -rf "$tmp_dir"
    }
}

_dl_and_concat_yt_playlist "$@" || print "$REPLY"



